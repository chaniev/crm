COMPOSE_PROJECT_NAME=gym-crm

ASPNETCORE_ENVIRONMENT=Production
BACKEND_PORT=8080
FRONTEND_PORT=3000
POSTGRES_DB=gym_crm
POSTGRES_USER=gym_crm
POSTGRES_PASSWORD=change-me

BACKEND_CLIENT_PHOTO_STORAGE_ROOT=/app/data/client-photos
BACKEND_CLIENT_PHOTO_MAX_UPLOAD_BYTES=10485760
BACKEND_APPLY_MIGRATIONS=true
BACKEND_FAIL_ON_MIGRATION_ERROR=true
BACKEND_AUTH_COOKIE_SECURE_POLICY=SameAsRequest
BACKEND_TECHNICAL_LOG_DIRECTORY=/app/logs/technical
BACKEND_TECHNICAL_LOG_FILE_PREFIX=gym-crm-api
BACKEND_TECHNICAL_LOG_FILE_SIZE_MB=20
BACKEND_TECHNICAL_LOG_RETENTION_DAYS=10
BOOTSTRAP_USER_LOGIN=headcoach
BOOTSTRAP_USER_FULL_NAME=Главный тренер

# При первом запуске API применяет миграции (если BACKEND_APPLY_MIGRATIONS=true)
# и создаёт bootstrap HeadCoach один раз на пустой базе.
# Значение BACKEND_AUTH_COOKIE_SECURE_POLICY=SameAsRequest оставлено для локального
# HTTP-запуска через docker compose; для реального HTTPS-деплоя переключите на Always.

FRONTEND_VITE_API_BASE_PATH=/api
FRONTEND_VITE_API_PROXY_TARGET=http://backend:8080

# Telegram-бот (MVP)
BOT_MODE=LongPolling
BOT_ENABLED=true
BOT_TELEGRAM_TOKEN=
BOT_TELEGRAM_PROXY_URL=
# MTProxy включает отдельный MTProto transport. Нужны api_id/api_hash из https://my.telegram.org.
# Можно указывать несколько MTProxy через запятую, точку с запятой или перенос строки.
# Поддерживаются форматы:
# - mtproxy://host:port/secret
# - tg://proxy?server=host&port=443&secret=secret
# - host:port:secret
BOT_TELEGRAM_MTPROXY_URLS=mtproxy://46.8.233.187:443/7nKHvkdpk6ZxkNvL6UYWezxwaWsucnU,mtproxy://stars-connect.duckdns.org:443/7hdv8GOe1VgjUtqOHfF3kbh3Yi5ydQ,mtproxy://tg1.cloxybot.ru:443/7ofuGQOSQnis_WmAOF3bmb9pbHRhcHVsdS5maQ,mtproxy://64.188.65.171:443/7pc8zexBElnR6sGVs4poqCB3d3cubWljcm9zb2Z0LmNvbQ,mtproxy://get.beatvault.ru:443/7vdQDWnQR56xyQRUSQqnCW1kcml2ZS5nb29nbGUuY29t,mtproxy://ghostnode.ru:65443/7k52euhk7my0SXtQK14xFcxnaG9zdG5vZGUucnU,mtproxy://gamma-roxy.ip-ddns.com:443/7pT8K0hK9uHhyH5ldrM8JXV2ay5jb20,mtproxy://dagdagdag.mooo.com:4444/dd94fc2b484af6e1e1c87e6576b33c2575,mtproxy://31.41.33.114:443/7uhUsiOWulp08jtvEmFuLm1pZC5ydQ,mtproxy://85.17.89.193:443/7nb2WD5rUJ2UbFYoepylncNicm93c2luZy55YW5kZXguY29t,mtproxy://88.99.194.177:443/7n0Wia-Y1eTY9sqg7RnXN7Zicm93c2luZy55YW5kZXguY29t,mtproxy://proxy-dag.ru:443/7pT8K0hK9uHhyH5ldrM8JXV5YS5ydQ,mtproxy://31.56.205.38:443/7nKHvkdpk6ZxkNvL6UYWezxwaWsucnU
BOT_TELEGRAM_API_ID=
BOT_TELEGRAM_API_HASH=
BOT_TELEGRAM_MTPROTO_SESSION_PATH=/app/data/bot/telegram-mtproto
BOT_TELEGRAM_PROXY_FAILOVER_DELAY_SECONDS=5
BOT_DATABASE_URL=postgresql+asyncpg://gym_crm:change-me@db:5432/gym_crm
CRM_API_BASE_URL=http://backend:8080
CRM_BOT_API_TOKEN=
BOT_INTERNAL_API_TOKEN=
BOT_INTERNAL_API_ENABLED=true
BOT_LOG_LEVEL=INFO
