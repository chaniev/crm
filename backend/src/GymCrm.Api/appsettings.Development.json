{
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=gym_crm;Username=gym_crm;Password=gym_crm;Include Error Detail=true"
  },
  "Persistence": {
    "ApplyMigrationsOnStartup": true,
    "FailStartupOnMigrationError": true
  },
  "BootstrapUser": {
    "Login": "headcoach",
    "FullName": "Главный тренер"
  },
  "ClientPhoto": {
    "MaxUploadSizeBytes": 10485760,
    "StorageRootPath": "uploads/client-photos"
  },
  "TechnicalLogging": {
    "Enabled": false,
    "DirectoryPath": "logs/technical",
    "FileNamePrefix": "gym-crm-api",
    "FileSizeLimitMb": 20,
    "RetentionDays": 10
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  }
}
